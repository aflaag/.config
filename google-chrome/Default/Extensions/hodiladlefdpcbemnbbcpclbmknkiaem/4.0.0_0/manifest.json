{
   "action": {
      "default_popup": "popup/popup.html",
      "default_title": "Visual Effects"
   },
   "background": {
      "service_worker": "./background.js",
      "type": "module"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "content/injectScripts.js" ],
      "matches": [ "*://meet.google.com/*" ],
      "run_at": "document_start"
   } ],
   "description": "Virtual Green Screens, Blur, Pixelate, 3D Filters and More!",
   "host_permissions": [ "*://meet.google.com/*" ],
   "icons": {
      "128": "icons/128.png",
      "32": "icons/32.png",
      "64": "icons/64.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Google Meet Enhanced Experience",
   "permissions": [ "storage" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "4.0.0",
   "web_accessible_resources": [ {
      "matches": [ "*://*/*" ],
      "resources": [ "dependencies/*", "content.js", "main.css", "img/*", "assets/*" ]
   } ]
}
